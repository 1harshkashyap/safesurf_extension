{
  "manifest_version": 3,
  "name": "SafeSurf AI",
  "short_name": "SafeSurf",
  "version": "5.0.0",
  "description": "AI-powered browser security platform. Real-time threat detection, behavioral anomaly analysis, domain reputation intelligence, deep explainability, and adaptive protection.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "webNavigation"
  ],

  "host_permissions": ["http://*/*", "https://*/*", "https://api.anthropic.com/*", "https://safebrowsing.googleapis.com/*", "https://urlhaus-api.abuse.ch/*"],

  "background": { "service_worker": "background.js" },

  "content_scripts": [{
    "matches": ["http://*/*", "https://*/*"],
    "js": ["content_script.js"],
    "css": ["content_style.css"],
    "run_at": "document_idle",
    "all_frames": false
  }],

  "action": {
    "default_popup": "popup.html",
    "default_title": "SafeSurf AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [{
    "resources": ["report.html", "report.js", "icons/*"],
    "matches": ["<all_urls>"]
  }]
}
